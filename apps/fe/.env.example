# Next.js Proxy API Configuration
# Target API URL (the API you want to proxy to)
TARGET_API_URL=https://api.example.com

# Custom headers to add to requests (JSON format)
# Example: {"Authorization": "Bearer token", "X-Custom-Header": "value"}
CUSTOM_HEADERS={}

# Response headers to hide from the client (comma-separated)
# Example: "server,set-cookie,x-powered-by"
HIDDEN_RESPONSE_HEADERS=server,set-cookie,x-powered-by
